SELECT
    [Category Name]
    ,ROUND(SUM([Sales]), 2) AS 'Total Sales'
    ,ROUND(SUM([Order Profit Per Order]), 2) AS 'Total Profit'
    ,ROUND(SUM([Order Profit Per Order]) / SUM([Sales]) * 100.0, 2) AS 'Profit Margin %'
    ,CASE
        WHEN ROUND(SUM([Order Profit Per Order]) / SUM([Sales]) * 100.0, 2) > 20 THEN 'High Margin'
        WHEN ROUND(SUM([Order Profit Per Order]) / SUM([Sales]) * 100.0, 2) > 10 THEN 'Moderate Margin'
        WHEN ROUND(SUM([Order Profit Per Order]) / SUM([Sales]) * 100.0, 2) > 0 THEN 'Low Margin'
        ELSE 'Losing Money'
    END AS 'Margin Band'
FROM DataCoSupplyChainDataset
GROUP BY [Category Name]
ORDER BY [Profit Margin %] DESC

Conclusion:
"Profit margin analysis by product category revealed variation in category efficiency, enabling the business to identify 
which categories convert revenue most effectively versus those requiring pricing or cost reviews."
