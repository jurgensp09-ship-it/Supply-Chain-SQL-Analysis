SELECT	
	[customer segment]
	,count([order id]) as 'Total Orders'
	,round(count([order id]) * 100.0 / (select count(*) from DataCoSupplyChainDataset), 2) as 'Order %'
	,round(sum([sales]),2) as 'Total Sales'
from DataCoSupplyChainDataset
group by [customer segment]
order by round(count([order id]) * 100.0 / (select count(*) from DataCoSupplyChainDataset), 2) DESC

--without average profit per segment--

SELECT	
    [Customer Segment]
    ,COUNT([Order Id]) AS 'Total Orders'
    ,ROUND(COUNT([Order Id]) * 100.0 / (SELECT COUNT(*) FROM DataCoSupplyChainDataset), 2) AS 'Order %'
    ,ROUND(SUM([Sales]), 2) AS 'Total Sales'
    ,ROUND(SUM([Order Profit Per Order]), 2) AS 'Total Profit'
    ,ROUND(SUM([Order Profit Per Order]) / SUM([Sales]) * 100.0, 2) AS 'Profit Margin %'
FROM DataCoSupplyChainDataset
GROUP BY [Customer Segment]
ORDER BY [Total Sales] DESC

--With profit per segment--

Conclusion:
"Consumer segment dominates with 51.8% of orders and $19M in sales, however profit margins are remarkably consistent 
across all three segments at approximately 10.6-10.9% — suggesting uniform pricing strategy regardless of customer type."
